{
    "name": "aldiazhar/laravel-agent-network",
    "description": "Multi-level agent commission engine generator for Laravel + Filament",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Aldi Azhar",
            "email": "permana.azhar.aldi@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "filament/filament": "^4.0|^5.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "AgentNetwork\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AgentNetwork\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AgentNetwork\\AgentNetworkServiceProvider"
            ],
            "aliases": {
                "AgentNetwork": "AgentNetwork\\Facades\\AgentNetwork"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
